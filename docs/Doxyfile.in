PROJECT_NAME           = "Tatnez Rumble Speaker"
PROJECT_NUMBER         = "@PROJECT_VERSION@"
OUTPUT_DIRECTORY       = "@DOXYGEN_OUTPUT_DIRECTORY@"
CREATE_SUBDIRS         = NO
OPTIMIZE_OUTPUT_FOR_C  = NO
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_XML           = NO
QUIET                  = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_AS_ERROR          = NO
INPUT                  = @DOXYGEN_INPUT_DIRECTORY@
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = README.md
FILE_PATTERNS          = *.h *.hpp *.cpp *.md
EXAMPLE_PATH           = docs/site/tutorials
HTML_OUTPUT            = html
HTML_COLORSTYLE        = LIGHT
HTML_DYNAMIC_SECTIONS  = YES
